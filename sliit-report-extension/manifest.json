{
  "manifest_version": 3,
  "name": "SLIIT Report Cover Page Generator",
  "version": "4.0.0",
  "description": "Instantly generate a professional SLIIT report cover page as PDF or Word document.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "SLIIT Report Cover Generator"
  },
  "permissions": ["storage"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}
