{
  "manifest_version": 2,
  "name": "SLIIT Report Cover Generator",
  "version": "4.0.0",
  "description": "Generate professional SLIIT report cover pages as PDF or Word — instantly.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "SLIIT Report Cover Generator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "sliit-cover@sliit.extension",
      "strict_min_version": "109.0"
    }
  }
}
